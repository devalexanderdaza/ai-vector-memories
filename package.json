{
  "name": "ai-vector-memories",
  "version": "1.0.0",
  "description": "AI Vector Memories is an open-source library that provides a powerful and efficient way to manage and utilize vector-based memories for AI applications. It offers a simple API for storing, retrieving, and manipulating high-dimensional vector representations of data, enabling developers to build intelligent systems that can learn from and reason about complex information.",
  "authors": [
    {
      "name": "Alexander Daza",
      "email": "dev.alexander.daza@gmail.com",
      "url": "https://github.com/devalexanderdaza"
    }
  ],
  "contributors": [
    {
      "name": "Alexander Daza",
      "email": "dev.alexander.daza@gmail.com",
      "url": "https://github.com/devalexanderdaza"
    }
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly && bun build src/memory/embedding-worker.ts --outdir dist/memory --target bun --format esm",
    "dev": "bun build src/index.ts --outdir dist --target bun --format esm --watch",
    "typecheck": "tsc --noEmit",
    "release": "semantic-release",
    "commit-lint": "commitlint --from=HEAD~1 --to=HEAD",
    "metrics:injection": "bun run scripts/metrics-injection-report.ts",
    "metrics:report": "bun run src/commands/metrics-report.ts",
    "prepare": "husky"
  },
  "keywords": [
    "opencode",
    "ai",
    "memory",
    "plugin",
    "persistent",
    "cognitive",
    "coding-assistant",
    "typescript",
    "javascript",
    "vector-database",
    "embedding",
    "retrieval",
    "long-term-memory",
    "short-term-memory",
    "context-awareness",
    "performance",
    "user-experience",
    "ruvector",
    "vector-store",
    "similarity-search",
    "semantic-search",
    "natural-language-processing",
    "machine-learning",
    "artificial-intelligence",
    "open-source"
  ],
  "author": {
    "name": "Alexander Daza",
    "email": "dev.alexander.daza@gmail.com",
    "url": "https://github.com/devalexanderdaza"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devalexanderdaza/ai-vector-memories.git"
  },
  "bugs": {
    "url": "https://github.com/devalexanderdaza/ai-vector-memories/issues"
  },
  "homepage": "https://github.com/devalexanderdaza/ai-vector-memories#readme",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@huggingface/transformers": "^4.0.0-next.1",
    "@opencode-ai/plugin": "^1.2.27",
    "@opencode-ai/sdk": "^1.2.27",
    "ruvector": "^0.2.16",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^22.0.0",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.3.11",
    "commitlint": "^20.5.0",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
