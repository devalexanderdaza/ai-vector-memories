{
  "name": "ai-vector-memories",
  "version": "0.0.1",
  "description": "A plugin for OpenCode AI that provides persistent, cognitive memory capabilities to enhance the coding assistant's performance and user experience.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "preversion": "bun run build",
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly && bun build src/memory/embedding-worker.ts --outdir dist/memory --target bun --format esm",
    "dev": "bun build src/index.ts --outdir dist --target bun --format esm --watch",
    "typecheck": "tsc --noEmit",
    "metrics:injection": "bun run scripts/metrics-injection-report.ts"
  },
  "keywords": [
    "opencode",
    "ai",
    "memory",
    "plugin",
    "persistent",
    "cognitive",
    "coding-assistant",
    "typescript",
    "javascript",
    "vector-database",
    "embedding",
    "retrieval",
    "long-term-memory",
    "short-term-memory",
    "context-awareness",
    "performance",
    "user-experience",
    "ruvector",
    "vector-store",
    "similarity-search",
    "semantic-search",
    "natural-language-processing",
    "machine-learning",
    "artificial-intelligence",
    "open-source"
  ],
  "author": {
    "name": "Alexander Daza",
    "email": "dev.alexander.daza@gmail.com",
    "url": "https://github.com/devalexanderdaza"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devalexanderdaza/ai-vector-memories.git"
  },
  "bugs": {
    "url": "https://github.com/devalexanderdaza/ai-vector-memories/issues"
  },
  "homepage": "https://github.com/devalexanderdaza/ai-vector-memories#readme",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@huggingface/transformers": "^4.0.0-next.1",
    "@opencode-ai/plugin": "^1.2.27",
    "@opencode-ai/sdk": "^1.2.27",
    "ruvector": "^0.2.16",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
